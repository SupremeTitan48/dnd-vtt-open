[Unit]
Description=DND VTT Backend
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/dnd-vtt
EnvironmentFile=/etc/dnd-vtt.env
ExecStart=/opt/dnd-vtt/.venv/bin/uvicorn net.signaling_service:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
User=dnd
Group=dnd

[Install]
WantedBy=multi-user.target
